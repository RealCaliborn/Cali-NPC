<?xml version="1.0"?>
<Definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <SpawnGroups>

        <!-- (NPC-GIRR) CruiserSpawn Hauler -->
        <SpawnGroup>
            <Id>
                <TypeId>SpawnGroupDefinition</TypeId>
                <SubtypeId>(NPC-GIRR) Mayday Hauler</SubtypeId>
            </Id>
            <Description>

            [Modular Encounters SpawnGroup]

            [RivalAiSpawn:true]
            [UseRivalAi:true]
            [RivalAiReplaceRemoteControl:true]

            [DisableDampeners:false]

            [SpaceCargoShip:false]
            [LunarCargoShip:false]
            [SpaceRandomEncounter:false]
            [AtmosphericCargoShip:false]
            [PlanetaryInstallation:false]

            [FactionOwner:GIRR]
            [ReplenishSystems:true]
            [AddDefenseShieldBlocks:true]

            [UseRivalAi:true]
            [RivalAiReplaceRemoteControl:true]
            [RotateFirstCockpitToForward:true]
            [ManipulationProfiles:MES-Manipulation-PropulsionGIRR]

            </Description>
            <IsPirate>true</IsPirate>
            <Frequency>1.0</Frequency>
            <Prefabs>
                <Prefab SubtypeId="(NPC-GIRR) Modified Hauler">
                    <Position>
                        <X>0.0</X>
                        <Y>0.0</Y>
                        <Z>0.0</Z>
                    </Position>
                    <Speed>400</Speed>
                    <Behaviour>BH-GIRR-Hauler-Mayday</Behaviour>
                </Prefab>
            </Prefabs>
        </SpawnGroup>
        <!-- (NPC-GIRR) CruiserSpawn Hauler -->

