<?xml version="1.0"?>
<Definitions xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <SpawnGroups>

    <SpawnGroup>
        <Id>
            <TypeId>SpawnGroupDefinition</TypeId> <!--Do Not Edit-->
            <SubtypeId>(NPC-GKNT) 1Sabre 1Swallow</SubtypeId>
        </Id>
        <Description>

        [Modular Encounters SpawnGroup] 
        [RivalAiSpawn:true]
        [SpaceRandomEncounter:false]
        [SpaceCargoShip:false]
        [LunarCargoShip:false]
        [AtmosphericCargoShip:false]
        [PlanetaryInstallation:false]
        [FactionOwner:GKNT]
        [ReplenishSystems:true]
                
        [UseRivalAi:true]
        [RivalAiReplaceRemoteControl:true]

        </Description>
        <IsPirate>true</IsPirate> <!--Do not edit-->
        <Frequency>1.0</Frequency>
        <Prefabs>
            <Prefab SubtypeId="(NPC-GKNT) Saber Heavy Fighter">
                <Position>
                    <X>250.2</X>
                    <Y>0.0</Y>
                    <Z>0.0</Z>
                </Position>
                <Speed>400</Speed>
                <Behaviour>BH-GKNT-Fighter-Default</Behaviour>
            </Prefab>
            <Prefab SubtypeId="(NPC-GKNT) Swallow Light Fighter">
                <Position>
                    <X>-250.2</X>
                    <Y>0.0</Y>
                    <Z>0.0</Z>
                </Position>
                <Speed>400</Speed>
                <Behaviour>BH-GKNT-Fighter-Default</Behaviour>
            </Prefab>
        </Prefabs>
    </SpawnGroup>

