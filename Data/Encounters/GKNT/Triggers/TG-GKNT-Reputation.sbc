<?xml version="1.0"?>
<Definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <EntityComponents>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>TG-GKNT-Reputation</SubtypeId>
      </Id>
      <Description>

        [RivalAI TriggerGroup]

        [Triggers:TR-GKNT-Reputation-GeneralDamage]
        [Triggers:TR-GKNT-Reputation-Compromised]
        [Triggers:TR-GKNT-Reputation-GrindDamage]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>TR-GKNT-Reputation-GeneralDamage</SubtypeId>
      </Id>
      <Description>

        [RivalAI Trigger]

        [UseTrigger:true]
        [Type:Damage]
        
        [DamageTypes:Any]
        [ExcludedDamageTypes:Environment]
        [ExcludedDamageTypes:Deformation]
        
        [MinCooldownMs:100]
        [MaxCooldownMs:101]
        [StartsReady:true]
        [MaxActions:-1]
        [Actions:AC-GKNT-Reputation-GeneralDamage]

      </Description>

    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>AC-GKNT-Reputation-GeneralDamage</SubtypeId>
      </Id>
      <Description>

        [RivalAI Action]

        [ChangeAttackerReputation:true]
        [ChangeAttackerReputationFaction:GKNT]
        [ChangeAttackerReputationAmount:-5]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>TR-GKNT-Reputation-Compromised</SubtypeId>
      </Id>
      <Description>

        [RivalAI Trigger]

        [UseTrigger:true]
        [Type:Compromised]
        [StartsReady:true]
        [MaxActions:-1]
        [Actions:AC-GKNT-Reputation-Compromised]

      </Description>

    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>AC-GKNT-Reputation-Compromised</SubtypeId>
      </Id>
      <Description>

        [RivalAI Action]

        [ChangeAttackerReputation:true]
        [ChangeAttackerReputationFaction:GKNT]
        [ChangeAttackerReputationAmount:-100]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>TR-GKNT-Reputation-GrindDamage</SubtypeId>
      </Id>
      <Description>

        [RivalAI Trigger]

        [UseTrigger:true]
        [Type:Damage]
        [DamageTypes:Grind]
        [MinCooldownMs:100]
        [MaxCooldownMs:101]
        [StartsReady:true]
        [MaxActions:-1]
        [Actions:AC-GKNT-Reputation-GrindDamage]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>AC-GKNT-Reputation-GrindDamage</SubtypeId>
      </Id>
      <Description>

        [RivalAI Action]

        [ChangeAttackerReputation:true]
        [ChangeAttackerReputationFaction:GKNT]
        [ChangeAttackerReputationAmount:-5]

        [BarrelRoll:true]

      </Description>
    </EntityComponent>

  </EntityComponents>
</Definitions>