	<EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>MES-Manipulation-Visual</SubtypeId>
      </Id>
      <Description>

        [MES Manipulation]

        [SkinRandomBlocks:true]
        [MinPercentageSkinRandomBlocks:0]
        [MaxPercentageSkinRandomBlocks:95]
        [SkinRandomBlocksTextures:Rusty_Armor]
        [SkinRandomBlocksTextures:Battered_Armor]
        [SkinRandomBlocksTextures:Heavy_Rust_Armor]

        [ReduceBlockBuildStates:false]
        [MinimumBlocksPercent:0]
        [MaximumBlocksPercent:8]
        [MinimumBuildPercent:51]
        [MaximumBuildPercent:90]
		
		[ShiftBlockColorsHue:true]
		[RandomHueShift:true]
		[ShiftBlockColorAmount:0]

      </Description>

    </EntityComponent>
    
  </EntityComponents>
</Definitions>