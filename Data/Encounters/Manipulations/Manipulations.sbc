<?xml version="1.0"?>
<Definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <EntityComponents>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>MES-Manipulation-PropulsionVOID</SubtypeId>
      </Id>
      <Description>

        [MES Manipulation]
		
		[ConfigureSpecialNpcThrusters:true]
		[RestrictNpcIonThrust:true]
		[NpcIonThrustForceMultiply:18]
		[NpcIonThrustPowerMultiply:0.01]
		
		[RestrictNpcAtmoThrust:true]
		[NpcAtmoThrustForceMultiply:18]
		[NpcAtmoThrustPowerMultiply:0.01]
		
		[RestrictNpcHydroThrust:true]
		[NpcHydroThrustForceMultiply:18]
		[NpcHydroThrustPowerMultiply:0.01]
		
		[SetNpcGyroscopeMultiplier:true]
		[NpcGyroscopeMultiplier:8]
		
		[AddDefenseShieldBlocks:true]
		[ChangeTurretSettings:true]
		[TurretRange:11000]
		[TurretIdleRotation:false]
		[TurretTargetMeteors:false]
		[TurretTargetSmallGrids:true]
		[TurretTargetLargeGrids:true]
		[TurretTargetNeutrals:false]
		
      </Description>

    </EntityComponent>
	    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
