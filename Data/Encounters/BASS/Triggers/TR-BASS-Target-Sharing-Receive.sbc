<?xml version="1.0"?>
<Definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <EntityComponents>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>TR-BASS-Target-Sharing-Receive</SubtypeId>
      </Id>
      <Description>

        [RivalAI Trigger]

        [UseTrigger:true]
        [Type:CommandReceived]

        [MinCooldownMs:2000]
        [MaxCooldownMs:2001]
        [StartsReady:true]
        [MaxActions:-1]
        [CommandReceiveCode:CO-BASS-Target-Sharing]
        [Actions:AC-BASS-Target-Sharing-Receive]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>AC-BASS-Target-Sharing-Receive</SubtypeId>
      </Id>
      <Description>

        [RivalAI Action]

        [SwitchToReceivedTarget:true]
        [InheritLastAttackerFromCommand:true]

      </Description>
    </EntityComponent>

  </EntityComponents>
</Definitions>
