            [LunarCargoShip:false]
            [SpaceRandomEncounter:false]
            [AtmosphericCargoShip:false]
            [PlanetaryInstallation:false]

            [FactionOwner:Nobody]
            [ReplenishSystems:false]

            [ClearGridInventories:true]
            [UseContainerTypeAssignment:true]
            [ContainerTypeAssignmentReference:Large Reward Container|ECHO Medium Reward]

            </Description>
            <IsPirate>true</IsPirate>
            <Frequency>1.0</Frequency>
            <Prefabs>
                <Prefab SubtypeId="(NPC-All) SI Loot Pod">
                    <Position>
                        <X>0.0</X>
                        <Y>0.0</Y>
                        <Z>0.0</Z>
                    </Position>
                    <Speed>25</Speed>
                    <Behaviour>BH-Common-None</Behaviour>
