<?xml version="1.0"?>
<Definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <SpawnGroups>
      <!-- (NPC-ECHO) Scarab -->
      <SpawnGroup>
        <Id>
            <TypeId>SpawnGroupDefinition</TypeId>
            <SubtypeId>(NPC-ECHO) Scarab (OUTER)</SubtypeId>
        </Id>
        <Description>

        [Modular Encounters SpawnGroup]
    
        [DisableDampeners:false]

        [SpaceCargoShip:true]

        [FactionOwner:ECHO]
        [ReplenishSystems:true]

        [UseRivalAi:true]
        [RivalAiReplaceRemoteControl:true]

        [UseThreatLevelCheck:true]
        [ThreatLevelCheckRange:10000]
        [ThreatScoreMinimum:-1]
        [ThreatScoreMaximum:1000]

        [UseContainerTypeAssignment:true]
        [ContainerTypeAssignmentReference:Large Cargo Container|ECHO Easy Reward,Small Cargo Container|ECHO Easy Reward]
        [AddDefenseShieldBlocks:true]
        [ReplaceArmorBlocksWithModules:true]
        [ManipulationProfiles:MES-Manipulation-PropulsionECHO]

        </Description>
        <IsPirate>true</IsPirate>
        <Frequency>0.5</Frequency>
        <Prefabs>
          <Prefab SubtypeId="(NPC-ECHO) Scarab">
              <Position>
                  <X>0.0</X>
                  <Y>0.0</Y>
                  <Z>0.0</Z>
              </Position>
              <Speed>25</Speed>
              <Behaviour>BH-ECHO-Scarab-Single</Behaviour>
          </Prefab>
        </Prefabs>
    </SpawnGroup>
    <!-- (NPC-ECHO) Scarab -->

    <!-- (NPC-ECHO) Scarab -->
    <SpawnGroup>
      <Id>
