<!-- (NPC-ECHO) Cargo Freighter Solo -->
      <SpawnGroup>
        <Id>
          <TypeId>SpawnGroupDefinition</TypeId>               <!--Do Not Edit-->
          <SubtypeId>(NPC-ECHO) Cargo Freighter Solo (PVE;NPC)</SubtypeId>
        </Id>
        <Description>

        [Modular Encounters SpawnGroup]

        [DisableDampeners:false]

        [SpaceCargoShip:true]

        [FactionOwner:ECHO]
        [ReplenishSystems:true]

        [UseRivalAi:true]
        [RivalAiReplaceRemoteControl:true]

        [IgnoreShieldProviderMod:true]
        [UseThreatLevelCheck:true]
        [ThreatLevelCheckRange:10000]
        [ThreatScoreMinimum:-1]
        [ThreatScoreMaximum:249]

        [UseContainerTypeAssignment:true]
        [ContainerTypeAssignmentReference:Large Cargo Container|ECHO Cargo Ship Default,Small Cargo Container|ECHO Cargo Ship Default]
        [InitializeStoreBlocks:true]
        [ContainerTypesForStoreOrders:PRTH Cargo Ship Default]
        [AddDefenseShieldBlocks:true]
        [ReplaceArmorBlocksWithModules:true]
        [ManipulationProfiles:MES-Manipulation-PropulsionECHO]

        </Description>
        <IsPirate>true</IsPirate>           <!--Do not edit-->
        <Frequency>0.5</Frequency>
        <Prefabs>
          <Prefab SubtypeId="(NPC-ECHO) Cargo Freighter">
            <Position>
              <X>0.0</X>
              <Y>0.0</Y>
              <Z>0.0</Z>
            </Position>
            <Speed>20</Speed>
            <Behaviour>BH-ECHO-Cargo-Solo</Behaviour>
          </Prefab>
        </Prefabs>
      </SpawnGroup>
<!-- (NPC-ECHO) Cargo Freighter Solo -->

