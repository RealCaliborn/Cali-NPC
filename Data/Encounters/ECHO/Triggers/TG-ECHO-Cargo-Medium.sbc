<?xml version="1.0"?>
<Definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <EntityComponents>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>TG-ECHO-Cargo-Medium</SubtypeId>
      </Id>
      <Description>

        [RivalAI TriggerGroup]

        [Triggers:TR-ECHO-Cargo-Medium-CallSupport-Damage]
        [Triggers:TR-ECHO-Cargo-Medium-CallSupport-Hostile]
        [Triggers:TR-ECHO-Cargo-Medium-CallSupport-Call]
        [Triggers:TR-ECHO-Cargo-Medium-CallSupport-Response]
        [Triggers:TR-ECHO-Cargo-Medium-CallSupport-Spawn]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>TR-ECHO-Cargo-Medium-CallSupport-Damage</SubtypeId>
      </Id>
      <Description>

        [RivalAI Trigger]
        [UseTrigger:true]
        [Type:Damage]
        [DamageTypes:Any]
        [ExcludedDamageTypes:Environment]
        [ExcludedDamageTypes:Deformation]
        [StartsReady:true]
        [MinCooldownMs:3000]
        [MaxCooldownMs:3001]
        [MaxActions:1]

        [Actions:AC-ECHO-Cargo-Medium-CallSupport-Damage]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>AC-ECHO-Cargo-Medium-CallSupport-Damage</SubtypeId>
      </Id>
      <Description>

        [RivalAI Action]
      
        [ResetCooldownTimeOfTriggers:true]
        [ResetTriggerCooldownNames:TR-ECHO-Cargo-Medium-CallSupport-Call]

        [EnableTriggers:true]
        [EnableTriggerNames:TR-ECHO-Cargo-Medium-CallSupport-Call]

        [DisableTriggers:true]
        [DisableTriggerNames:TR-ECHO-Cargo-Medium-CallSupport-Damage]
        [DisableTriggerNames:TR-ECHO-Cargo-Medium-CallSupport-Hostile]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>TR-ECHO-Cargo-Medium-CallSupport-Hostile</SubtypeId>
      </Id>
      <Description>

        [RivalAI Trigger]
        [UseTrigger:true]
        [Type:PlayerNear]
        [TargetDistance:6000]
        [MinPlayerReputation:-1500]
        [MaxPlayerReputation:-501]
        [StartsReady:true]
        [MinCooldownMs:3000]
        [MaxCooldownMs:3001]
        [MaxActions:1]

        [Actions:AC-ECHO-Cargo-Medium-CallSupport-Hostile]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>AC-ECHO-Cargo-Medium-CallSupport-Hostile</SubtypeId>
      </Id>
      <Description>

        [RivalAI Action]
      
        [ResetCooldownTimeOfTriggers:true]
        [ResetTriggerCooldownNames:TR-ECHO-Cargo-Medium-CallSupport-Call]

        [EnableTriggers:true]
        [EnableTriggerNames:TR-ECHO-Cargo-Medium-CallSupport-Call]

        [DisableTriggers:true]
        [DisableTriggerNames:TR-ECHO-Cargo-Medium-CallSupport-Damage]
        [DisableTriggerNames:TR-ECHO-Cargo-Medium-CallSupport-Hostile]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>TR-ECHO-Cargo-Medium-CallSupport-Call</SubtypeId>
      </Id>
      <Description>

        [RivalAI Trigger]
        [UseTrigger:false]
        [Type:Timer]
        [StartsReady:false]
        [MinCooldownMs:0]
        [MaxCooldownMs:1]
        [MaxActions:1]

        [Actions:AC-ECHO-Cargo-Medium-CallSupport-Call]

      </Description>
      
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>AC-ECHO-Cargo-Medium-CallSupport-Call</SubtypeId>
      </Id>
      <Description>

        [RivalAI Action]
      
        [UseChatBroadcast:true]
        [ChatData:CH-ECHO-Cargo-All-CallSupport-Call]

        [ResetCooldownTimeOfTriggers:true]
        [ResetTriggerCooldownNames:TR-ECHO-Cargo-Medium-CallSupport-Response]

        [EnableTriggers:true]
        [EnableTriggerNames:TR-ECHO-Cargo-Medium-CallSupport-Response]

        [DisableTriggers:true]
        [DisableTriggerNames:TR-ECHO-Cargo-Medium-CallSupport-Call]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>TR-ECHO-Cargo-Medium-CallSupport-Response</SubtypeId>
      </Id>
      <Description>

        [RivalAI Trigger]
        [UseTrigger:false]
        [Type:Timer]
        [StartsReady:false]
        [MinCooldownMs:2000]
        [MaxCooldownMs:2001]
        [MaxActions:1]

        [Actions:AC-ECHO-Cargo-Medium-CallSupport-Response]

      </Description>
      
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>AC-ECHO-Cargo-Medium-CallSupport-Response</SubtypeId>
      </Id>
      <Description>

        [RivalAI Action]
      
        [UseChatBroadcast:true]
        [ChatData:CH-ECHO-Cargo-All-CallSupport-Affirmative]

        [ResetCooldownTimeOfTriggers:true]
        [ResetTriggerCooldownNames:TR-ECHO-Cargo-Medium-CallSupport-Spawn]

        [EnableTriggers:true]
        [EnableTriggerNames:TR-ECHO-Cargo-Medium-CallSupport-Spawn]

        [DisableTriggers:true]
        [DisableTriggerNames:TR-ECHO-Cargo-Medium-CallSupport-Response]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>TR-ECHO-Cargo-Medium-CallSupport-Spawn</SubtypeId>
      </Id>
      <Description>

        [RivalAI Trigger]
        [UseTrigger:false]
        [Type:Timer]
        [StartsReady:false]
        [MinCooldownMs:2000]
        [MaxCooldownMs:2001]
        [MaxActions:1]

        [Actions:AC-ECHO-Cargo-Medium-CallSupport-Spawn]

      </Description>
      
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>AC-ECHO-Cargo-Medium-CallSupport-Spawn</SubtypeId>
      </Id>
      <Description>

        [RivalAI Action]
      
        [DisableTriggers:true]
        [DisableTriggerNames:TR-ECHO-Cargo-Medium-CallSupport-Spawn]

        [SpawnEncounter:true]
        [Spawner:SP-ECHO-Cargo-Medium-CallSupport-Spawn]
        [Spawner:SP-ECHO-Cargo-Medium-CallSupport-Spawn]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>SP-ECHO-Cargo-Medium-CallSupport-Spawn</SubtypeId>
      </Id>
      <Description>

      [RivalAI Spawn]
      
      [UseSpawn:true]
      
      [SpawningType:CustomSpawn]
      [StartsReady:true]
      [SpawnMinCooldown:0]
      [MaxSpawns:1]
      
      [SpawnGroups:(NPC-GKNT) 1Sabre 1Swallow]
      
      [UseRelativeSpawnPosition:false]
      [MinDistance:500]
      [MaxDistance:1000]
      [IgnoreSafetyChecks:false]
      
      </Description>
    </EntityComponent>

  </EntityComponents>
</Definitions>