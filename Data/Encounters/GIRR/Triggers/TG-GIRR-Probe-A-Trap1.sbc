<?xml version="1.0"?>
<Definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <EntityComponents>

    <!-- Trigger Group TG-GIRR-Transport is all of the Transport-specific triggers -->
    <!-- This file contains all related triggers, actions, and chats -->
    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>TG-GIRR-Probe-A-Trap1</SubtypeId>
      </Id>
      <Description>

        [RivalAI TriggerGroup]

        [Triggers:TR-GIRR-Probe-A-Send]
        [Triggers:TR-GIRR-Probe-A-Player-Near]
        [Triggers:TR-GIRR-Probe-A-Trap1-Player-Really-Near]
      </Description>
    </EntityComponent>

    <!-- This block covers chatter when the first turret locks on the first target -->
    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>TR-GIRR-Probe-A-Trap1-Player-Really-Near</SubtypeId>
      </Id>
      <Description>

        [RivalAI Trigger]

        [MinCooldownMs:6000]

        [UseTrigger:true]
        [Type:PlayerNear]
        [TargetDistance:4800]
        [StartsReady:true]
        [MaxActions:1]
        [Actions:AC-GIRR-Probe-A-Trap1-Player-Really-Near]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>AC-GIRR-Probe-A-Trap1-Player-Really-Near</SubtypeId>
      </Id>
      <Description>

        [RivalAI Action]

        [UseChatBroadcast:true]
        [ChatData:CH-GIRR-Probe-A-Player-Really-Near]

        [SpawnEncounter:true]
        [Spawner:SP-GIRR-Probe-A-Trap1-Player-Really-Near]
        [Spawner:SP-GIRR-Probe-A-Trap1-Player-Really-Near]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>SP-GIRR-Probe-A-Trap1-Player-Really-Near</SubtypeId>
      </Id>
      <Description>

      [RivalAI Spawn]
      
      [UseSpawn:true]
      
      [SpawningType:CustomSpawn]
      [StartsReady:true]
      [SpawnMinCooldown:0]
      [MaxSpawns:-1]
      
      [SpawnGroups:(NPC-GIRR) CruiserSpawn Hauler]
      [SpawnGroups:(NPC-GIRR) CruiserSpawn Transport]
      [SpawnGroups:(NPC-GIRR) CruiserSpawn Miner]
      [SpawnGroups:(NPC-GIRR) CruiserSpawn Merchant]
      
      [UseRelativeSpawnPosition:false]
      [MinDistance:2500]
      [MaxDistance:4000]
      [IgnoreSafetyChecks:false]

      </Description>
    </EntityComponent>

  </EntityComponents>
</Definitions>
