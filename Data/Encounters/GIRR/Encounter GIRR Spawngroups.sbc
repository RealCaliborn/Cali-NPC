			</Id>
			<Description>

            [Modular Encounters SpawnGroup]

            [DisableDampeners:false]
            [SpaceRandomEncounter:true]
			[AddDefenseShieldBlocks:true]
            [FactionOwner:GIRR]
            [ReplenishSystems:true]
            [UseRivalAi:true]
            [RivalAiReplaceRemoteControl:true]
            [RotateFirstCockpitToForward:false]
			[ManipulationProfiles:MES-Manipulation-PropulsionGIRR]

            </Description>
			<IsPirate>true</IsPirate>
			<Frequency>2.0</Frequency>
