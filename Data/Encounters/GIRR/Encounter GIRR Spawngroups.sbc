						<Y>0.0</Y>
						<Z>0.0</Z>
					</Position>
					<Speed>0</Speed>
					<Behaviour>BH-GIRR-Probe-A</Behaviour>
				</Prefab>
			</Prefabs>
		</SpawnGroup>
