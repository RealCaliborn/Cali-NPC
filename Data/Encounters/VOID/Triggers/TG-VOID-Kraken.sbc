        [ResetCooldownTimeOfTriggers:true]
        [ResetTriggerCooldownNames:TR-VOID-Kraken-LaunchFighter-Port]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>TR-VOID-Kraken-ReceiveFighter-Starboard</SubtypeId>
      </Id>
      <Description>

        [RivalAI Trigger]

        [UseTrigger:true]
        [Type:CommandReceived]
        [MinCooldownMs:0]
        [MaxCooldownMs:1]
        [StartsReady:true]
        [MaxActions:-1]
        [CommandReceiveCode:CO-VOID-Baby-Answering-Starboard]
        [Actions:AC-VOID-Kraken-ReceiveFighter-Starboard]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>AC-VOID-Kraken-ReceiveFighter-Starboard</SubtypeId>
      </Id>
      <Description>

        [RivalAI Action]

        [ResetCooldownTimeOfTriggers:true]
        [ResetTriggerCooldownNames:TR-VOID-Kraken-LaunchFighter-Starboard]

      </Description>
    </EntityComponent>









    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>TR-VOID-Kraken-ShieldsDown-Spawn</SubtypeId>
      </Id>
      <Description>

        [RivalAI Trigger]

        [UseTrigger:true]
        [Type:Damage]
        [DamageTypes:Deformation]
        [StartsReady:true]
        [MaxActions:-1]
        [Actions:AC-VOID-Kraken-ShieldsDown-Spawn]

      </Description>

    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>AC-VOID-Kraken-ShieldsDown-Spawn</SubtypeId>
      </Id>
      <Description>

        [RivalAI Action]

        [SpawnEncounter:true]
        [Spawner:SP-VOID-Kraken-ShieldsDown-Spawn]

        [UseChatBroadcast:true]
        [ChatData:CH-VOID-Kraken-ShieldsDown-Spawn]

        [DisableTriggers:true]
        [DisableTriggerNames:TR-VOID-Kraken-ShieldsDown-Spawn]

      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>SP-VOID-Kraken-ShieldsDown-Spawn</SubtypeId>
      </Id>
      <Description>

      [RivalAI Spawn]
      
      [UseSpawn:true]
      
      [SpawningType:SpaceCargoShip]
      [StartsReady:true]
      [SpawnMinCooldown:0]
      [MaxSpawns:1]
      
      [SpawnGroups:(NPC-VOID) 1xLampreyB]
      
      [UseRelativeSpawnPosition:false]
      [MinDistance:1500]
      [MaxDistance:2500]
      [IgnoreSafetyChecks:false]
      
      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>CH-VOID-Kraken-ShieldsDown-Spawn</SubtypeId>
      </Id>
      <Description>

        [RivalAI Chat]

        [UseChat:true]
        [StartsReady:true]
        [Author:Kraken]
        [Color:Red]

        [Chance:100]
        [MaxChats:1]

        [IgnoreAntennaRequirement:true]
        [IgnoredAntennaRangeOverride:10000]

        [ChatMessages:Send the reserves in!]
        [BroadcastChatType:Chat]

      </Description>
    </EntityComponent>









  </EntityComponents>
</Definitions>